@BASE_URL = http://localhost:3000

### login
POST {{BASE_URL}}/auth/login
Content-Type: application/json

{
  "email": "admin1@email.com",
  "password": "123456"
}

### register
POST {{BASE_URL}}/auth/register
Content-Type: application/json

{
  "username": "admin",
  "email": "admin1@email.com",
  "password": "123456",
  "role": "ADMIN"
}

